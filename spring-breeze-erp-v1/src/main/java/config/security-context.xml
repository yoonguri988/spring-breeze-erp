<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xmlns:context="http://www.springframework.org/schema/context"
	xmlns:security="http://www.springframework.org/schema/security"
	xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd
		http://www.springframework.org/schema/context http://www.springframework.org/schema/context/spring-context-4.3.xsd
		http://www.springframework.org/schema/security http://www.springframework.org/schema/security/spring-security-4.2.xsd">
   <!-- 암호화 : BCrypt -->
   <bean id="passwordEncoder" 
         class="org.springframework.security.crypto.bcrypt.BCryptPasswordEncoder"/>
   <!-- 로그인성공 --> 
   <bean id="successHandler"
         class="com.sb.erp.security.LoginSuccessHandler"/>
   <!-- 로그인실패-권한x --> 
   <bean id="deniedHandler"
         class="com.sb.erp.security.DeniedHandler"/>
   <!-- 유저정보  -->
   <bean id="customUserDetailsService"
         class="com.sb.erp.security.CustomUserDetailsService"/>

   <security:http>
   	  <!-- cyj : 추후 접근 권한 변경 -->
      <!-- <security:intercept-url  pattern="/security/all"     access="permitAll" /> -->
      <!-- <security:intercept-url  pattern="/security/member"  access="hasRole('ROLE_MEMBER')" /> -->

      <security:intercept-url  pattern="/auth/login" access="permitAll" />
      <security:intercept-url  pattern="/auth/resetPass" access="permitAll" />
      <!-- <security:intercept-url  pattern="/auth/**"    access="isAuthenticated()" /> -->
	
      <!-- KJY -->
      <security:intercept-url  pattern="/appr/**" access="isAuthenticated()"/>
      <!-- KJY -->
      
      <!-- jsj -->
      <security:intercept-url  pattern="/emp/add" access="hasRole('ROLE_ADMIN')"/>
      <security:intercept-url  pattern="/emp/edit" access="hasRole('ROLE_ADMIN')"/>
      <security:intercept-url  pattern="/emp/**" access="isAuthenticated()"/>
      <!-- jsj -->

   	  <security:intercept-url  pattern="/board/**" access="permitAll" />
   	  
   	  
   	  <!-- jang -->
   	  <security:intercept-url pattern="/admin/**" access="permitAll"/>
   	  <!-- jang -->
   	  
   	  
   	  <security:intercept-url pattern="/error/**" access="permitAll"/>
   	  
   	  <security:intercept-url pattern="/index" access="isAuthenticated()"/>
   	  <security:intercept-url pattern="/com/**" access="isAuthenticated()"/>
   	  <security:intercept-url pattern="/dept/**" access="isAuthenticated()"/>
   	  <!-- cyj -->
   	  
	  <security:form-login
	  	  login-page="/auth/login"
	  	  login-processing-url="/auth/login"
	  	  authentication-success-handler-ref="successHandler"
	  	  authentication-failure-url="/auth/fail"
	  />
	  
	  <security:logout 
	      logout-url="/auth/logout"
	      logout-success-url="/auth/login"
	      invalidate-session="true"/>
	  <!-- cyj : 추후 접근 권한 변경 -->
   </security:http>

   <security:authentication-manager>
      <security:authentication-provider   user-service-ref="customUserDetailsService">
         <security:password-encoder      ref="passwordEncoder"/>
      </security:authentication-provider>
   </security:authentication-manager>
</beans>

   <!-- 유저정보  
   1. permitAll : 모두 다 접근가능
   2. hasRole('ROLE_MEMBER')  : ROLE_MEMBER 권한
   3. isAuthenticated()       : 인증된 사용자  (로그인)
   ※ 구체적인 패턴을 위에, 포괄패턴은 아래
   -->