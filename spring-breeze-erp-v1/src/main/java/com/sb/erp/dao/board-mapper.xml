<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<!-- Son.C.K -->
<!-- 1page (페이징 -select, 검색 -select)  2page (공지사항등록 - insert) 3page (상세페이지-select / update(조회수) )
     4page (수정수정페이지-select / update(수정기능)  )   -->
     
<mapper namespace="com.sb.erp.dao.BoardMapper">
 
  <insert         id="insert"   parameterType="BoardDto" >
    insert into  notice (com_id , btitle , bcontent , emp_id , bhit, bfile)  
    values  ( #{com_id} ,  #{btitle} ,  #{bcontent} , #{emp_id} , #{bhit} , #{bfile})
  </insert>
  
  <update         id="update"   parameterType="BoardDto">
  	update  notice  
  	set  btitle = #{btitle}  , bcontent = #{bcontent}  , bfile = #{bfile}
  	where emp_id = #{emp_id}
  </update>
  
  <delete         id="delete"  parameterType="int">
    delete  from   notice  where bno= #{bno} 
  </delete>
  
  <select  resultType="BoardDto"   id="selectAll"   >
  	select * from   notice  order by bno desc
  </select>
  
  <select resultType="BoardDto"   id="select"   parameterType="int">
  	select * from    notice  where  bno= #{bno}
  </select>
  
  <update   id="updateHit"  parameterType="int">
  	update  notice  set  bhit = bhit + 1  where  bno= #{bno}
  </update>
   
  <!-- 	paging	 -->
  <!-- 	paging	 -->
  <select    resultType="BoardDto"   id="select10"  parameterType="java.util.HashMap">
  	select * from   notice  order by bno desc  limit  #{start} , #{end}
  </select>
  

  <select    resultType="int"   id="selectCnt"  >
    select  count(*)  from   notice
  </select>
  
</mapper>

