<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.sb.erp.dao.DeptMapper">

	<select id="selectAll" resultType="DeptDto">
		select dept_id, dept_name 
		from department
		order by dept_name
	</select>

</mapper>