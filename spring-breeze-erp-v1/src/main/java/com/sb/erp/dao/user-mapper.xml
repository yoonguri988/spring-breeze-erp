<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.sb.erp.dao.UserMapper">
	
	<insert id="insertUser" parameterType="UserDto">
		insert into users (user_id, user_pass, user_email)
		values (#{user_id}, #{user_pass}, #{user_email})
	</insert>
	
	<select id="findByEmail" parameterType="string"  resultType="UserDto">
		 select * from users where user_email=#{user_email}
	</select>
	
	<select resultMap="authListMap" id="readAuth" parameterType="string">
	   select    u.user_id,  u.user_pass,  a.auth
	   from      users u    left   join authorities a 
	   on u.user_id   = a.user_id  
	   where     u.user_id =#{user_id} 
	</select>
	<!-- authorities 테이블 옆에 left join 사용해서 부서 테이블도 이어야하고
		 users 테이블에 회사 id 값도 추가적으로 들어가야할거같음
		 left join 부서 테이블명 d on u.dept_id = d.dept_id -->
	
	<resultMap id="authListMap" type="AuthUserDto">
	     <result  property="user_id" column="user_id" />
	     <result  property="user_pass" column="user_pass" />
	     <!-- dept left join 했으면 여기도 추가 -->
	     <collection property="authList" resultMap="authMap" />
	</resultMap>
	
	<resultMap id="authMap" type="AuthDto" > 
	     <result property="auth" column="auth" />
	</resultMap>  
	
</mapper>