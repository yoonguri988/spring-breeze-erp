  <!-- 공지 게시글 등록 (insert 구문 포함) -->
  <!-- ✅ PK(bno) 자동 생성 후 DTO에 매핑되도록 옵션 추가 -->
  <insert id="insert" parameterType="NoticeDto" >
    insert into notice (btitle, bcontent, emp_id, com_id
    	<if test="bfile != null and bfile != ''">, bfile</if>
    )  
    values (#{btitle}, #{bcontent}, #{empId}, #{comId}
    	<if test="bfile != null and bfile != ''">, #{bfile}</if>
    )
  </insert>
  
  <!-- 상세 페이지 조회 -->
  <select id="select" resultType="NoticeDto" parameterType="int">
    select * from notice where bno = #{bno}
  </select>
  
  <!-- 조회수 증가 -->
  <update id="updateHit" parameterType="int">
    update notice set bhit = bhit + 1 where bno = #{bno}
  </update>
  
  <!-- 삭제 -->
  <delete id="delete" parameterType="int">
    delete from notice where bno = #{bno}
  </delete>
  
  <!-- 공지 수정 -->
  <update id="update" parameterType="NoticeDto">
    update notice
    set btitle   = #{btitle}
        , bcontent = #{bcontent}
        <if test="bfile != null and bfile != ''">, bfile    = #{bfile}</if>
    where bno = #{bno}
  </update>
  
  <!-- 페이징 -->
  <select id="selectAll" resultType="NoticeDto" parameterType="NoticeSearchDto">
    select * from notice
    <where>
    	<if test="keyword != null and keyword != ''">
    	and (lower(btitle) like lower(CONCAT('%', #{keyword}, '%'))
           or lower(bcontent) like lower(CONCAT('%', #{keyword}, '%')))
    	</if>
    </where>
    order by bno desc
    <if test="sortBy == 'new'">, created_at desc</if>
    <if test="sortBy == 'views'">, created_at desc</if>
    limit #{pstartno}, #{onepagelist}
  </select>

  <!-- 전체 카운트 -->
  <select id="selectCount" resultType="int">
    select count(*) from notice
  </select>
  
  <!-- 공지글 페이징 + 검색 (제목/내용) -->
  <!-- <select id="selectNoticeList" resultType="NoticeDto" parameterType="NoticeSearchDto">
