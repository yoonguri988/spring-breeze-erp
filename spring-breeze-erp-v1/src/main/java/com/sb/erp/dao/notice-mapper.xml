  </select> 
   -->
  <!-- 검색 결과 카운트 -->
  <select id="selectCountNoticeList" resultType="int" parameterType="NoticeSearchDto">
    select count(*) as total_count
    from notice
    where (lower(btitle) like lower(CONCAT('%', #{keyword}, '%'))
           or lower(bcontent) like lower(CONCAT('%', #{keyword}, '%')))
  </select>  
</mapper>
